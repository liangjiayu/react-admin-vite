{
  "name": "antd-admin-template",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "preview": "vite preview",
    "prepare": "husky",
