      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@ant-design/pro-components": "3.1.12-0",
    "@react-router/node": "^7.14.0",
    "ahooks": "^3.8.5",
    "antd": "^6.3.5",
    "antd-style": "^4.1.0",
    "axios": "^1.10.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "isbot": "^5.1.37",
    "lodash-es": "^4.17.21",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.13.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.10",
    "zustand": "^5.0.6"
